# Database Configuration
POSTGRES_DB_URI=jdbc:postgresql://localhost:5432/learn_hub_activities
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATA=

INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=

# Server Configuration
SERVER_PORT=5001
CLIENT_PORT=3001

# LLM Configuration (OpenAI-compatible API)
# base-url must include the /v1 API root (Spring AI 2.0 appends /chat/completions verbatim).
LLM_BASE_URL=https://gpu.aet.cit.tum.de/ollama/v1
LLM_API_KEY=REDACTED
LLM_MODEL_NAME=qwen3:30b-a3b
# Optional image generation for exercise illustrations. Reuses LLM_BASE_URL + LLM_API_KEY
# above (the endpoint must support image generation), enabled once LLM_IMAGE_MODEL_NAME is set.
LLM_IMAGE_MODEL_NAME=
LLM_IMAGE_SIZE=1536x1024
LLM_IMAGE_QUALITY=medium
LLM_IMAGE_USER=learn-hub

# Session Authentication
# Optional overrides:
# SESSION_TIMEOUT=7d
# SESSION_COOKIE_MAX_AGE=7d
# SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_SAME_SITE=lax
# CLIENT_ALLOWED_ORIGINS=https://your-app.example.com

# Email Configuration (STARTTLS only)
EMAIL_ADDRESS=your_email@example.com
EMAIL_USERNAME=your_email@example.com
EMAIL_PASSWORD=your_email_password
EMAIL_SENDER_NAME=LEARN-Hub Team
SMTP_SERVER=postout.lrz.de
SMTP_PORT=587

PDF_PATH=/path/to/pdf/storage/on/host/machine

# GITHUB
GITHUB_REPOSITORY=ls1intum/learn-hub
IMAGE_TAG=latest

# Client Environment (for UI version display)
# Options: local, staging, production
ENVIRONMENT=local

# Development
VERBOSE_LOGGING=false # Server logging verbosity (true/false)
